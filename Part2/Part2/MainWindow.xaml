<Window x:Class="Part2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="850"
        Width="520"
        Background="#EAFBF3"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Grid x:Name="MainGrid">

        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="140"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Border x:Name="HeaderBorder"
                Grid.Row="0"
                Background="#2FBF71"
                CornerRadius="0,0,25,25">

            <Grid Margin="15">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <!-- LOGO -->
                <Border Width="65"
                        Height="66"
                        Background="#A7F3D0"
                        CornerRadius="32"
                        VerticalAlignment="Bottom"
                        Margin="8,0,7,2">

                    <TextBlock Text="Bot"
                               FontSize="26"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- TITLE -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">

                    <TextBlock Text="Cybersecurity Awareness Bot"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock x:Name="txtStatus"
                               Text="Chatbot • Tasks • Quiz • Security Learning"
                               FontSize="13"
                               Foreground="#E7FFF3"/>
                </StackPanel>

                <!-- ICON -->
                <TextBlock Grid.Column="2"
                           Text="🛡️"
                           FontSize="30"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ================= CHAT AREA ================= -->
        <ScrollViewer x:Name="ChatScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Margin="15">

            <StackPanel x:Name="ChatPanel"/>
        </ScrollViewer>

        <!-- ================= INPUT + BUTTON PANEL ================= -->
        <Border Grid.Row="2"
                Background="#FFFFFF"
                CornerRadius="20"
                Margin="10"
                BorderBrush="#A7F3D0"
                BorderThickness="2">

            <Grid Margin="10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- INPUT + SEND -->
                <Grid Grid.Row="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="txtUserInput"
                             Background="#F0FDF4"
                             Foreground="#14532D"
                             BorderBrush="#86EFAC"
                             BorderThickness="1"
                             Padding="10"
                             FontSize="14"
                             VerticalContentAlignment="Center"/>

                    <Button x:Name="btnSend"
                            Grid.Column="1"
                            Content="Send"
                            Click="btnSend_Click"
                            Background="#22C55E"
                            Foreground="White"
                            Margin="10,0,0,0"/>
                </Grid>

                <!-- ACTION BUTTONS -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">

                    <Button Content=" Quiz"
                            Width="80"
                            Margin="5"
                            Click="btnQuiz_Click"
                            Background="#16A34A"
                            Foreground="White"/>

                    <Button Content=" Task"
                            Width="80"
                            Margin="5"
                            Click="btnAddTask_Click"
                            Background="#22C55E"
                            Foreground="White"/>

                    <Button Content=" Log"
                            Width="80"
                            Margin="5"
                            Click="btnLog_Click"
                            Background="#15803D"
                            Foreground="White"/>

                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</Window>